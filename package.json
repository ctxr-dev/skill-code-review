{
  "name": "@ctxr/skill-code-review",
  "version": "1.3.0",
  "description": "Claude Code skill — wiki-organised corpus of ~476 specialist reviewer leaves selected by semantic tree descent against the diff, aggregated into an 8-gate GO/NO-GO release verdict.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctxr-dev/skill-code-review.git"
  },
  "homepage": "https://github.com/ctxr-dev/skill-code-review#readme",
  "bugs": {
    "url": "https://github.com/ctxr-dev/skill-code-review/issues"
  },
  "keywords": [
    "claude-code",
    "skill",
    "code-review",
    "ai",
    "agents",
    "agentskills"
  ],
  "files": [
    "SKILL.md",
    "code-reviewer.md",
    "release-readiness.md",
    "report-format.md",
    "reviewers.wiki/",
    "fsm/",
    "scripts/",
    "docs/code-reviewer-design.md",
    ".fsmrc.json",
    "README.md",
    "LICENSE"
  ],
  "ctxr": {
    "type": "skill",
    "target": "folder"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:e2e": "node --test tests/integration/end-to-end-runner.test.js",
    "test:src": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "index:build:src": "node scripts/build-index-src.mjs",
    "validate:body-shape": "node scripts/validate-body-shape.mjs",
    "validate:dimensions": "node scripts/validate-dimensions.mjs",
    "validate:fsm": "fsm-validate-static fsm/code-reviewer.fsm.yaml",
    "validate:src": "npm run index:build:src && npm run validate:body-shape && npm run validate:dimensions && npm run validate:fsm",
    "review": "node scripts/run-review.mjs",
    "lint": "markdownlint-cli2 '**/*.md' '#node_modules' '#.skill-code-review'",
    "lint:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#.skill-code-review'",
    "prepare": "husky",
    "prepublishOnly": "npm run validate:fsm && npm run lint && npm test"
  },
  "dependencies": {
    "@ctxr/fsm": "git+https://github.com/ctxr-dev/fsm.git#721d79e9ba93248c0e9ee0b94b328c15ac80bff7"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "husky": "^9.1.0",
    "markdownlint-cli2": "^0.14.0"
  }
}
